{
  "name": "superpowers-manager",
  "version": "0.2.0",
  "description": "Install and update the latest stable obra/superpowers release directly from upstream, without waiting for agent marketplaces to catch up. Codex supported today.",
  "keywords": [
    "superpowers",
    "obra-superpowers",
    "agent-skills",
    "ai-coding-agent",
    "coding-agent",
    "agent-harness",
    "codex",
    "codex-plugin",
    "plugin-manager",
    "cli",
    "installer",
    "updater"
  ],
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.16.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "node --input-type=module -e \"import{existsSync}from'node:fs';if(!existsSync('dist/cli.js')){console.error('error: dist/cli.js is missing — run pnpm install --frozen-lockfile && pnpm run build');process.exit(1)}\"",
    "lint": "oxlint src/ bin/ tests/bin/",
    "format": "prettier --write src/ bin/ tests/bin/",
    "format:check": "prettier --check src/ bin/ tests/bin/",
    "typecheck:js": "tsc -p tests/tsconfig.json",
    "check": "pnpm run format:check && pnpm run lint && pnpm run build && pnpm run typecheck:js && node tests/bin/units.test.js"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "oxlint": "^1.75.0",
    "oxlint-tsgolint": "7.0.2001",
    "prettier": "^3.9.6",
    "typescript": "~7.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j7an/superpowers-manager.git"
  },
  "homepage": "https://github.com/j7an/superpowers-manager#readme",
  "bugs": {
    "url": "https://github.com/j7an/superpowers-manager/issues"
  },
  "bin": {
    "superpowers-manager": "bin/superpowers-manager.js"
  },
  "engines": {
    "node": ">=24"
  },
  "files": [
    "bin/",
    "dist/",
    "scripts/",
    "config/upstream-ref",
    ".agents/plugins/marketplace.json",
    "plugins/superpowers/.codex-plugin/plugin.template.json",
    "README.md"
  ]
}
