#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
. "$root/scripts/core/common.sh"
. "$root/scripts/core/upstream.sh"
. "$root/scripts/core/selection.sh"

[ "$#" -eq 1 ] || spw_usage_error 'usage: superpowers-manager pin REF'
requested_ref="$1"

if spw_is_pinnable_tag "$requested_ref"; then
  requested_kind=tag
elif spw_is_full_commit "$requested_ref"; then
  requested_kind=raw-commit
else
  spw_usage_error 'pin REF must be an exact v-prefixed SemVer tag or full 40-hex commit'
fi

spw_require_command python3
state_path=$(spw_selection_state_path)
tmp_parent="${TMPDIR:-/tmp}"
if ! pin_workspace=$(spw_make_workspace "$tmp_parent" "superpowers-manager.pin"); then
  spw_die "cannot create pin workspace under $tmp_parent"
fi
spw_install_workspace_trap "$pin_workspace"

normalized="$pin_workspace/selection.json"
spw_selection_state "$root" read \
  --path="$state_path" --output="$normalized"

source="${SUPERPOWERS_UPSTREAM_URL:-$SPW_UPSTREAM_URL_DEFAULT}"
spw_selection_state "$root" \
  validate-source --source="$source"

if [ "$requested_kind" = tag ]; then
  spw_require_command git
  commit=$(spw_resolve_exact_tag "$source" "$requested_ref")
  resolved_ref="$requested_ref"
else
  spw_require_command git
  requested_ref=$(printf '%s' "$requested_ref" | tr '[:upper:]' '[:lower:]')
  resolved_ref="$requested_ref"
  commit=$(spw_verify_raw_commit "$source" "$requested_ref" "$pin_workspace")
fi

spw_selection_state "$root" write-pinned \
  --path="$state_path" --source="$source" --requested-ref="$requested_ref" \
  --resolved-ref="$resolved_ref" --commit="$commit"

printf 'pinned upstream selection to %s at %s\n' "$requested_ref" "$commit"
