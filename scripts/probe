#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
. "$root/scripts/core/common.sh"
. "$root/scripts/core/upstream.sh"
. "$root/scripts/core/provenance.sh"
. "$root/scripts/core/status.sh"
. "$root/scripts/core/lifecycle.sh"
. "$root/scripts/core/adapter.sh"

upstream_url="${SUPERPOWERS_UPSTREAM_URL:-$SPW_UPSTREAM_URL_DEFAULT}"
requested_ref=$(spw_config_ref "$root")
resolved_record=$(spw_resolve_ref "$upstream_url" "$requested_ref")
resolved_ref=$(printf '%s\n' "$resolved_record" | awk '{ print $2 }')
desired_commit=$(printf '%s\n' "$resolved_record" | awk '{ print $3 }')

generated_commit=$(spw_generated_commit_or_empty "$root")
tmp_parent="${TMPDIR:-/tmp}"
if ! probe_workspace=$(mktemp -d "$tmp_parent/superpowers-wrapper.probe.XXXXXX"); then
  spw_die "cannot create probe workspace under $tmp_parent"
fi
inspect_result="$probe_workspace/inspect.json"
cleanup() {
  status=$?
  trap - 0 HUP INT TERM
  rm -rf "$probe_workspace" || :
  exit "$status"
}
trap cleanup 0
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

TMPDIR="$probe_workspace"
export TMPDIR
spw_inspect_fingerprint "$inspect_result"
installed_commit=$(spw_adapter_result_get "$inspect_result" "fingerprint")

status=$(spw_status_for_commits "$desired_commit" "$generated_commit" "$installed_commit")

if [ "${1:-}" = "--porcelain" ]; then
  printf 'requested_ref=%s\n' "$requested_ref"
  printf 'resolved_ref=%s\n' "$resolved_ref"
  printf 'desired_commit=%s\n' "$desired_commit"
  printf 'generated_commit=%s\n' "$generated_commit"
  printf 'installed_commit=%s\n' "$installed_commit"
  printf 'status=%s\n' "$status"
else
  printf 'requested ref: %s\n' "$requested_ref"
  printf 'resolved ref: %s\n' "$resolved_ref"
  printf 'desired commit: %s\n' "$desired_commit"
  printf 'generated plugin commit: %s\n' "${generated_commit:-not present}"
  printf 'installed wrapper commit or fingerprint: %s\n' "${installed_commit:-not detected}"
  printf 'status: %s\n' "$status"
fi
