#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
. "$root/scripts/core/common.sh"
. "$root/scripts/core/provenance.sh"
. "$root/scripts/core/lifecycle.sh"
. "$root/scripts/core/adapter.sh"

spw_require_command python3

tmp_parent="${TMPDIR:-/tmp}"
if ! uninstall_workspace=$(mktemp -d "$tmp_parent/superpowers-wrapper.uninstall.XXXXXX"); then
  spw_die "cannot create uninstall workspace under $tmp_parent"
fi
inspect_result="$uninstall_workspace/inspect.json"
uninstall_result="$uninstall_workspace/uninstall.json"
cleanup() {
  status=$?
  trap - 0 HUP INT TERM
  rm -rf "$uninstall_workspace" || :
  exit "$status"
}
trap cleanup 0
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

TMPDIR="$uninstall_workspace"
export TMPDIR

spw_inspect_ownership "$inspect_result"
plugin_present=$(spw_adapter_result_boolean "$inspect_result" "resources.plugin")
marketplace_present=$(spw_adapter_result_boolean "$inspect_result" "resources.marketplace")

spw_adapter_uninstall "$uninstall_result" "$plugin_present" "$marketplace_present"

spw_inspect_ownership "$inspect_result"
spw_verify_uninstalled_resources "$inspect_result"

echo "uninstall complete"
echo "note: local generated artifacts under plugins/superpowers/ and .cache/upstream/ were left in place; remove them manually or regenerate with scripts/prepare."
