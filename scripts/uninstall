#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
. "$root/scripts/lib.sh"

codex_bin="${SUPERPOWERS_CODEX:-codex}"

spw_require_command "$codex_bin"
spw_require_command python3

tmp_parent="${TMPDIR:-/tmp}"
inspect_result="$tmp_parent/.superpowers.uninstall.inspect.$$.json"
uninstall_result="$tmp_parent/.superpowers.uninstall.result.$$.json"
cleanup() {
  rm -f "$inspect_result" "$inspect_result.response" "$uninstall_result" "$uninstall_result.response"
}
trap cleanup EXIT HUP INT TERM

spw_inspect_ownership "$inspect_result"
plugin_present=$(spw_adapter_result_boolean "$inspect_result" "resources.plugin")
marketplace_present=$(spw_adapter_result_boolean "$inspect_result" "resources.marketplace")

spw_adapter_uninstall "$uninstall_result" "$plugin_present" "$marketplace_present"

spw_inspect_ownership "$inspect_result"
spw_verify_uninstalled_resources "$inspect_result"

echo "uninstall complete"
echo "note: local generated artifacts under plugins/superpowers/ and .cache/upstream/ were left in place; remove them manually or regenerate with scripts/prepare."
