#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)

probe_output=$(sh "$root/scripts/probe" --porcelain)
status=$(printf '%s\n' "$probe_output" | awk -F= '$1 == "status" { print $2 }')

case "$status" in
  current)
    printf '%s\n' "$probe_output"
    echo "wrapper is current"
    ;;
  needs\ prepare)
    sh "$root/scripts/prepare"
    sh "$root/scripts/install"
    ;;
  needs\ install)
    sh "$root/scripts/install"
    ;;
  *)
    echo "$probe_output"
    echo "error: unknown probe status: $status" >&2
    exit 1
    ;;
esac
