#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
. "$root/scripts/lib.sh"

probe_output=$(sh "$root/scripts/probe" --porcelain)
status=$(printf '%s\n' "$probe_output" | awk -F= '$1 == "status" { print $2 }')

case "$status" in
  current)
    printf '%s\n' "$probe_output"
    echo "manager is current"
    ;;
  needs\ prepare)
    sh "$root/scripts/prepare"
    sh "$root/scripts/install"
    desired_commit=$(spw_metadata_commit_or_empty "$root/plugins/superpowers/.superpowers-upstream.json" || true)
    [ -n "$desired_commit" ] || spw_die "generated metadata missing desired commit after install"
    spw_verify_refresh "$desired_commit"
    ;;
  needs\ install)
    sh "$root/scripts/install"
    desired_commit=$(spw_metadata_commit_or_empty "$root/plugins/superpowers/.superpowers-upstream.json" || true)
    [ -n "$desired_commit" ] || spw_die "generated metadata missing desired commit after install"
    spw_verify_refresh "$desired_commit"
    ;;
  *)
    echo "$probe_output"
    echo "error: unknown probe status: $status" >&2
    exit 1
    ;;
esac
