#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
. "$root/scripts/core/common.sh"
. "$root/scripts/core/lifecycle.sh"

probe_output=$(sh "$root/scripts/probe" --porcelain)
identity_state=$(spw_probe_field "$probe_output" identity_state)
[ -n "$identity_state" ] || spw_die "probe did not report adapter identity state"
spw_require_no_legacy_state "$identity_state"
status=$(spw_probe_field "$probe_output" status)
update_control=$(spw_probe_field "$probe_output" update_control)
[ -n "$update_control" ] || spw_die "probe did not report adapter update-control capability"

case "$status" in
  current)
    spw_require_managed_update_control "$update_control"
    printf '%s\n' "$probe_output"
    echo "manager is current"
    ;;
  needs\ prepare)
    sh "$root/scripts/prepare"
    sh "$root/scripts/install"
    ;;
  needs\ install)
    sh "$root/scripts/install"
    ;;
  *)
    echo "$probe_output"
    echo "error: unknown probe status: $status" >&2
    exit 1
    ;;
esac
