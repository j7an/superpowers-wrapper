#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
. "$root/scripts/lib.sh"

codex_bin="${SUPERPOWERS_CODEX:-codex}"
refresh_mode="${SUPERPOWERS_INSTALL_REFRESH_MODE:-add-only}"

spw_require_command "$codex_bin"
spw_require_command python3

case "$refresh_mode" in
  add-only|remove-add) ;;
  *) spw_die "unsupported SUPERPOWERS_INSTALL_REFRESH_MODE: $refresh_mode" ;;
esac

echo "Note: remove or disable conflicting Superpowers providers yourself before relying on manager-provided skills."

# Prepare-before-mutate: probe, and (re)generate the plugin tree if it is
# missing or stale — including validation — entirely before any Codex
# marketplace or plugin mutation. A failed prepare leaves Codex untouched.
probe_output=$(sh "$root/scripts/probe" --porcelain)
status=$(printf '%s\n' "$probe_output" | awk -F= '$1 == "status" { print $2 }')
case "$status" in
  needs\ prepare)
    sh "$root/scripts/prepare"
    ;;
  needs\ install|current)
    ;;
  *)
    printf '%s\n' "$probe_output"
    spw_die "unknown probe status: $status"
    ;;
esac

desired_commit=$(spw_metadata_commit_or_empty "$root/plugins/superpowers/.superpowers-upstream.json" || true)
[ -n "$desired_commit" ] || spw_die "generated metadata missing desired commit after prepare"

# Reconcile the manager marketplace pointer to this package root, then always
# run the Codex install step: `install` means "make Codex use this root" and
# never skips it because the generated tree looks current.
spw_reconcile_marketplace "$codex_bin" "$root"

case "$refresh_mode" in
  remove-add)
    "$codex_bin" plugin remove "$SPW_PLUGIN_ID" || true
    ;;
esac

if ! "$codex_bin" plugin add "$SPW_PLUGIN_ID"; then
  spw_die "codex plugin add failed for $SPW_PLUGIN_ID"
fi

spw_verify_refresh "$desired_commit"
