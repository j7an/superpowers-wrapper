#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
. "$root/scripts/core/common.sh"
. "$root/scripts/core/provenance.sh"
. "$root/scripts/core/status.sh"
. "$root/scripts/core/lifecycle.sh"
. "$root/scripts/core/adapter.sh"

spw_require_command python3

echo "Note: remove or disable conflicting Superpowers providers yourself before relying on manager skills."

# Prepare-before-mutate: probe, and (re)generate the plugin tree if it is
# missing or stale — including validation — entirely before any Codex
# marketplace or plugin mutation. A failed prepare leaves Codex untouched.
probe_output=$(sh "$root/scripts/probe" --porcelain)
identity_state=$(printf '%s\n' "$probe_output" | awk -F= '$1 == "identity_state" { print $2 }')
[ -n "$identity_state" ] || spw_die "probe did not report adapter identity state"
spw_require_no_legacy_state "$identity_state"
status=$(printf '%s\n' "$probe_output" | awk -F= '$1 == "status" { print $2 }')
case "$status" in
  needs\ prepare)
    sh "$root/scripts/prepare"
    ;;
  needs\ install|current)
    ;;
  *)
    printf '%s\n' "$probe_output"
    spw_die "unknown probe status: $status"
    ;;
esac

desired_commit=$(spw_metadata_commit_or_empty "$root/plugins/superpowers/.superpowers-upstream.json" || true)
[ -n "$desired_commit" ] || spw_die "generated metadata missing desired commit after prepare"

tmp_parent="${TMPDIR:-/tmp}"
if ! install_workspace=$(spw_make_workspace "$tmp_parent" "superpowers-manager.install"); then
  spw_die "cannot create install workspace under $tmp_parent"
fi
spw_install_workspace_trap "$install_workspace"

TMPDIR="$install_workspace"
export TMPDIR
install_result="$install_workspace/install.json"
inspect_result="$install_workspace/inspect.json"
ownership_result="$install_workspace/ownership.json"
update_control_result="$install_workspace/update-control.json"
spw_inspect_ownership "$ownership_result"
spw_inspect_update_control "$update_control_result"
identity_state=$(spw_adapter_result_get "$ownership_result" "identity_state")
update_control=$(spw_adapter_result_get "$update_control_result" "update_control")
spw_require_no_legacy_state "$identity_state"
spw_require_managed_update_control "$update_control"
spw_adapter_install "$install_result" "$root"
if ! spw_verify_installed_fingerprint "$desired_commit" "$install_result" "$inspect_result"; then
  exit 1
fi
