#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
. "$root/scripts/core/common.sh"
. "$root/scripts/core/provenance.sh"
. "$root/scripts/core/status.sh"
. "$root/scripts/core/lifecycle.sh"
. "$root/scripts/core/adapter.sh"

spw_require_command python3

echo "Note: remove or disable conflicting Superpowers providers yourself before relying on wrapper skills."

# Prepare-before-mutate: probe, and (re)generate the plugin tree if it is
# missing or stale — including validation — entirely before any Codex
# marketplace or plugin mutation. A failed prepare leaves Codex untouched.
probe_output=$(sh "$root/scripts/probe" --porcelain)
status=$(printf '%s\n' "$probe_output" | awk -F= '$1 == "status" { print $2 }')
case "$status" in
  needs\ prepare)
    sh "$root/scripts/prepare"
    ;;
  needs\ install|current)
    ;;
  *)
    printf '%s\n' "$probe_output"
    spw_die "unknown probe status: $status"
    ;;
esac

desired_commit=$(spw_metadata_commit_or_empty "$root/plugins/superpowers/.superpowers-upstream.json" || true)
[ -n "$desired_commit" ] || spw_die "generated metadata missing desired commit after prepare"

tmp_parent="${TMPDIR:-/tmp}"
install_result="$tmp_parent/.superpowers.install.$$.json"
cleanup() {
  rm -f "$install_result" "$install_result.response"
}
trap cleanup EXIT HUP INT TERM
spw_adapter_install "$install_result" "$root"
spw_verify_installed_fingerprint "$desired_commit" "$install_result"
trap - EXIT HUP INT TERM
cleanup
