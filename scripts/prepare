#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
. "$root/scripts/lib.sh"

upstream_url="${SUPERPOWERS_UPSTREAM_URL:-$SPW_UPSTREAM_URL_DEFAULT}"
cache_parent="${SUPERPOWERS_CACHE_DIR:-$root/.cache/upstream}"
cache="$cache_parent/superpowers"
plugin_root="${SUPERPOWERS_PLUGIN_ROOT:-$root/plugins/superpowers}"
manifest_template="${SUPERPOWERS_MANIFEST_TEMPLATE:-$root/plugins/superpowers/.codex-plugin/plugin.template.json}"
builtin_validator="$root/scripts/validate-generated-plugin.py"
additional_validator="${SUPERPOWERS_VALIDATOR:-}"
tmp_parent=$(dirname "$plugin_root")
tmp_plugin="$tmp_parent/.superpowers.tmp.$$"
requested_ref=$(spw_config_ref "$root")

spw_require_command git
spw_require_command python3
[ -f "$manifest_template" ] || spw_die "missing fallback manifest template: $manifest_template"
[ -f "$builtin_validator" ] || spw_die "missing built-in plugin validator: $builtin_validator"

resolved_record=$(spw_resolve_ref "$upstream_url" "$requested_ref")
resolution_kind=$(printf '%s\n' "$resolved_record" | awk '{ print $1 }')
resolved_ref=$(printf '%s\n' "$resolved_record" | awk '{ print $2 }')
commit=$(printf '%s\n' "$resolved_record" | awk '{ print $3 }')

mkdir -p "$cache_parent" "$tmp_parent"
if [ -d "$cache/.git" ]; then
  if ! git -C "$cache" fetch --tags --prune "$upstream_url"; then
    spw_die "cannot fetch upstream repo: $upstream_url"
  fi
else
  if ! git clone "$upstream_url" "$cache"; then
    spw_die "cannot clone upstream repo: $upstream_url"
  fi
fi
if ! git -C "$cache" checkout --detach "$commit" >/dev/null; then
  spw_die "cannot check out upstream commit: $commit"
fi

spw_require_upstream_path "$cache/skills" "skills/"
spw_require_upstream_path "$cache/LICENSE" "LICENSE"
spw_require_upstream_path "$cache/README.md" "README.md"
spw_require_upstream_path "$cache/CODE_OF_CONDUCT.md" "CODE_OF_CONDUCT.md"

rm -rf "$tmp_plugin"
mkdir -p "$tmp_plugin/.codex-plugin"
upstream_manifest="$cache/.codex-plugin/plugin.json"
if [ -f "$upstream_manifest" ]; then
  cp "$upstream_manifest" "$tmp_plugin/.codex-plugin/plugin.json"
else
  cp "$manifest_template" "$tmp_plugin/.codex-plugin/plugin.json"
fi

spw_copy_path_if_present "$cache/skills" "$tmp_plugin/skills"
spw_copy_path_if_present "$cache/assets" "$tmp_plugin/assets"
spw_copy_path_if_present "$cache/LICENSE" "$tmp_plugin/LICENSE"
spw_copy_path_if_present "$cache/README.md" "$tmp_plugin/README.md"
spw_copy_path_if_present "$cache/CODE_OF_CONDUCT.md" "$tmp_plugin/CODE_OF_CONDUCT.md"

upstream_manifest_version=""
if [ -f "$upstream_manifest" ]; then
  upstream_manifest_version=$(spw_json_get "$upstream_manifest" "version")
fi

spw_write_metadata_json \
  "$tmp_plugin/.superpowers-upstream.json" \
  "$upstream_url" \
  "$requested_ref" \
  "$resolved_ref" \
  "$commit" \
  "$upstream_manifest_version"

wrapper_version=$(
  spw_manifest_version_for_ref "$requested_ref" "$resolution_kind" "$resolved_ref" "$commit"
)
spw_apply_manifest_overlay \
  "$tmp_plugin/.codex-plugin/plugin.json" \
  "$wrapper_version"

# The validator must inspect the exact complete tree that will be swapped.
cp "$manifest_template" "$tmp_plugin/.codex-plugin/plugin.template.json"

if ! python3 -S "$builtin_validator" \
  --plugin-root "$tmp_plugin" \
  --source "$upstream_url" \
  --requested-ref "$requested_ref" \
  --resolved-ref "$resolved_ref" \
  --commit "$commit" \
  --manifest-version "$wrapper_version" \
  --upstream-manifest-version "$upstream_manifest_version"; then
  spw_die "built-in generated plugin validation failed"
fi

if [ -n "$additional_validator" ]; then
  [ -f "$additional_validator" ] || \
    spw_die "additional plugin validator not found: $additional_validator"
  if ! python3 "$additional_validator" "$tmp_plugin"; then
    spw_die "additional plugin validation failed"
  fi
fi

# Replace the live tree with a single atomic rename, keeping a backup so a
# failed swap restores the previous working generated tree (the spec requires
# that a failed prepare never destroy it). tmp_plugin is a same-filesystem
# sibling of plugin_root, so the renames cannot fail mid-copy.
backup="$tmp_parent/.superpowers.bak.$$"
rm -rf "$backup"
if [ -e "$plugin_root" ]; then
  mv "$plugin_root" "$backup"
fi
if mv "$tmp_plugin" "$plugin_root"; then
  rm -rf "$backup"
else
  if [ -e "$backup" ]; then
    mv "$backup" "$plugin_root"
  fi
  rm -rf "$tmp_plugin"
  spw_die "failed to install generated tree into $plugin_root; previous tree restored"
fi

echo "prepared $resolved_ref at $commit"
