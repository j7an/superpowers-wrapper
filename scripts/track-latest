#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
. "$root/scripts/core/common.sh"
. "$root/scripts/core/upstream.sh"
. "$root/scripts/core/selection.sh"

[ "$#" -eq 0 ] || spw_usage_error 'usage: superpowers-manager track-latest'

spw_require_command python3
state_path=$(spw_selection_state_path)
tmp_parent="${TMPDIR:-/tmp}"
if ! track_workspace=$(spw_make_workspace "$tmp_parent" "superpowers-manager.track-latest"); then
  spw_die "cannot create track-latest workspace under $tmp_parent"
fi
spw_install_workspace_trap "$track_workspace"

normalized="$track_workspace/selection.json"
spw_selection_state "$root" read \
  --path="$state_path" --output="$normalized"

source="${SUPERPOWERS_UPSTREAM_URL:-$SPW_UPSTREAM_URL_DEFAULT}"
spw_selection_state "$root" \
  validate-source --source="$source"

spw_selection_state "$root" write-track-latest \
  --path="$state_path" --source="$source"

printf '%s\n' 'saved upstream selection: latest stable release'
