    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitReturns": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2024",
    "types": ["node"]
  },
  "include": ["../bin/**/*.js", "bin/**/*.js"]
}
