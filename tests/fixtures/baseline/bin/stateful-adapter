#!/bin/sh
set -eu

operation=${1:-}
[ -n "$operation" ] || {
  echo "error: missing adapter operation" >&2
  exit 2
}
shift

python3 -S - "${SPW_BASELINE_ADAPTER_STATE:-}" "$operation" "$@" <<'PY'
import json
import os
from pathlib import Path
import re
import sys

state_directory_text, operation, *arguments = sys.argv[1:]
allowed_operations = {"build", "inspect", "install", "uninstall"}


def emit(envelope):
    json.dump(envelope, sys.stdout, allow_nan=False, separators=(",", ":"))
    sys.stdout.write("\n")


def fail(code, message):
    emit({
        "protocol": 1,
        "operation": operation,
        "ok": False,
        "messages": [],
        "result": None,
        "error": {"code": code, "message": message, "hints": []},
    })
    raise SystemExit(1)


def succeed(result):
    emit({
        "protocol": 1,
        "operation": operation,
        "ok": True,
        "messages": [],
        "result": result,
        "error": None,
    })


if operation not in allowed_operations:
    fail(
        "unsupported-operation",
        f"unsupported adapter operation: {operation}",
    )

view = None
if operation == "inspect":
    if len(arguments) == 1:
        view = arguments[0]
    elif len(arguments) == 2 and arguments[0] == "--view":
        view = arguments[1]
    else:
        fail("invalid-arguments", "inspect requires exactly one view")
    if view not in {"fingerprint", "ownership", "update-control"}:
        fail("invalid-arguments", f"unsupported inspect view: {view}")

if not state_directory_text:
    fail("invalid-state", "SPW_BASELINE_ADAPTER_STATE is required")
state_directory = Path(state_directory_text)
if not state_directory.is_dir():
    fail("invalid-state", "baseline adapter state directory is missing")

log_path_text = os.environ.get("SPW_BASELINE_ADAPTER_LOG")
if log_path_text:
    log_path = Path(log_path_text)
    if not log_path.parent.is_dir():
        fail("invalid-state", "baseline adapter log parent is missing")
    label = f"{operation} {view}" if view else operation
    with log_path.open("a", encoding="utf-8") as handle:
        handle.write(f"{label}\n")

initial_state = {
    "plugin": False,
    "marketplace": False,
    "legacy_plugin": False,
    "legacy_marketplace": False,
    "update_control": "managed",
    "fingerprint": None,
}
state_file = state_directory / "state.json"


def reject_constant(value):
    raise ValueError(f"non-standard JSON constant: {value}")


def reject_duplicates(pairs):
    result = {}
    for key, value in pairs:
        if key in result:
            raise ValueError(f"duplicate state key: {key}")
        result[key] = value
    return result


if state_file.exists():
    try:
        with state_file.open(encoding="utf-8") as handle:
            state = json.load(
                handle,
                parse_constant=reject_constant,
                object_pairs_hook=reject_duplicates,
            )
    except (OSError, UnicodeError, json.JSONDecodeError, ValueError, RecursionError):
        fail("invalid-state", "baseline adapter state is malformed")
else:
    state = initial_state.copy()

if not isinstance(state, dict) or set(state) != set(initial_state):
    fail("invalid-state", "baseline adapter state has an invalid schema")
for field in ("plugin", "marketplace", "legacy_plugin", "legacy_marketplace"):
    if type(state[field]) is not bool:
        fail("invalid-state", f"baseline adapter state field {field} must be Boolean")
if state["update_control"] not in {"managed", "unsupported"}:
    fail("invalid-state", "baseline adapter update control is invalid")
fingerprint = state["fingerprint"]
if fingerprint is not None and (
    not isinstance(fingerprint, str)
    or re.fullmatch(r"(?:[0-9A-Fa-f]{7}|[0-9A-Fa-f]{40})", fingerprint) is None
):
    fail("invalid-state", "baseline adapter fingerprint is invalid")
if not (state["plugin"] or state["marketplace"]) and fingerprint is not None:
    fail("invalid-state", "baseline adapter fingerprint has no owned resource")

if (
    view == "update-control"
    and os.environ.get("SPW_BASELINE_UPDATE_CONTROL_RESPONSE") == "malformed"
):
    sys.stdout.write("{\n")
    raise SystemExit(0)


def write_state():
    temporary = state_directory / f".state.json.tmp.{os.getpid()}"
    try:
        with temporary.open("x", encoding="utf-8") as handle:
            json.dump(state, handle, allow_nan=False, separators=(",", ":"))
            handle.write("\n")
        os.chmod(temporary, 0o600)
        os.replace(temporary, state_file)
    except (OSError, UnicodeError, ValueError, RecursionError):
        try:
            temporary.unlink()
        except OSError:
            pass
        fail("state-write-failed", "cannot persist baseline adapter state")


if operation == "build":
    runtime_adapter_text = os.environ.get("SPW_BASELINE_RUNTIME_ADAPTER")
    if not runtime_adapter_text:
        fail("invalid-state", "SPW_BASELINE_RUNTIME_ADAPTER is required for build")
    runtime_adapter = Path(runtime_adapter_text)
    if not runtime_adapter.is_absolute() or not runtime_adapter.is_file():
        fail("invalid-state", "baseline runtime adapter must be an absolute regular file")
    sandbox_root_text = os.environ.get("SPW_BASELINE_SANDBOX_ROOT")
    sandbox_root = Path(sandbox_root_text) if sandbox_root_text else None
    if (
        sandbox_root is None
        or not sandbox_root.is_absolute()
        or not sandbox_root.is_dir()
        or os.path.commonpath((
            str(runtime_adapter.resolve()),
            str(sandbox_root.resolve()),
        )) != str(sandbox_root.resolve())
    ):
        fail(
            "invalid-state",
            "baseline runtime adapter must be contained in sandbox root",
        )
    if not os.access(runtime_adapter, os.X_OK):
        fail("invalid-state", "baseline runtime adapter is not executable")
    try:
        os.execv(
            str(runtime_adapter),
            [str(runtime_adapter), operation, *arguments],
        )
    except OSError:
        fail("build-delegation-failed", "cannot execute baseline runtime adapter")
elif operation == "install":
    desired_fingerprint = os.environ.get("SPW_BASELINE_FINGERPRINT")
    if not desired_fingerprint:
        fail("invalid-arguments", "SPW_BASELINE_FINGERPRINT is required for install")
    if re.fullmatch(r"(?:[0-9A-Fa-f]{7}|[0-9A-Fa-f]{40})", desired_fingerprint) is None:
        fail("invalid-arguments", "SPW_BASELINE_FINGERPRINT must be 7 or 40 hex")
    installed_fingerprint = os.environ.get(
        "SPW_BASELINE_INSTALLED_FINGERPRINT",
        desired_fingerprint,
    )
    if re.fullmatch(r"(?:[0-9A-Fa-f]{7}|[0-9A-Fa-f]{40})", installed_fingerprint) is None:
        fail(
            "invalid-arguments",
            "SPW_BASELINE_INSTALLED_FINGERPRINT must be 7 or 40 hex",
        )
    state["plugin"] = True
    state["marketplace"] = True
    state["fingerprint"] = installed_fingerprint
    write_state()
    succeed({"verification_hints": {}})
elif operation == "uninstall":
    if os.environ.get("SPW_BASELINE_UNINSTALL_NOOP") != "1":
        state["plugin"] = False
        state["marketplace"] = False
        state["fingerprint"] = None
        write_state()
    succeed({})
elif view == "fingerprint":
    succeed({"view": "fingerprint", "fingerprint": state["fingerprint"]})
elif view == "update-control":
    succeed({
        "view": "update-control",
        "update_control": state["update_control"],
    })
else:
    manager_present = state["plugin"] or state["marketplace"]
    legacy_present = state["legacy_plugin"] or state["legacy_marketplace"]
    identity_state = {
        (False, False): "neither",
        (True, False): "manager",
        (False, True): "legacy",
        (True, True): "both",
    }[(manager_present, legacy_present)]
    succeed({
        "view": "ownership",
        "resources": {
            "plugin": state["plugin"],
            "marketplace": state["marketplace"],
        },
        "legacy_resources": {
            "plugin": state["legacy_plugin"],
            "marketplace": state["legacy_marketplace"],
        },
        "identity_state": identity_state,
    })
PY
